{
  "buildCommand": "cd frontend && npm install && npm run build-only",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/*.py": {
      "runtime": "python3.11"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
```

Save it. Then push:
